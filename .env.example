# Copy this file to .env before starting the stack.
# Generate passwords with a password manager and a JWT secret with:
#   openssl rand -base64 48

MYSQL_DATABASE=volunteer_db
MYSQL_USER=volunteer_app
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-long-random-password

JWT_SECRET=replace-with-a-base64-encoded-secret

# Leave these empty if email delivery is not needed.
MAIL_USERNAME=
MAIL_PASSWORD=

